# ===============================
# Server Config
# ===============================
NODE_ENV=development || production

PORT = SET_YOUR_PORT_HERE

# ===============================
# CORS
# ===============================
CORS_ORIGIN=SET_YOUR_CORS_ORIGIN_HERE (comma-separated list of allowed origins, e.g. https://example.com,http://localhost:3000)
# ===============================
# Database
# ===============================
MONGO_URI=SET_YOUR_MONGO_URI_HERE

# ===============================
# JWT Config
# ===============================
JWT_SECRET=SET_YOUR_JWT_SECRET_HERE
JWT_SECRET_EXPIRY=2h
JWT_REFRESH_SECRET=SET_YOUR_JWT_REFRESH_SECRET_HERE
JWT_REFRESH_SECRET_EXPIRY=7d

# ===============================
#CLOUDINARY Config
# ===============================
CLOUDINARY_CLOUD_NAME=SET_YOUR_CLOUDINARY_CLOUD_NAME_HERE
CLOUDINARY_API_KEY=SET_YOUR_CLOUDINARY_API_KEY_HERE
CLOUDINARY_API_SECRET=SET_YOUR_CLOUDINARY_API_SECRET_HERE

# ===============================
# Email Config (Nodemailer Gmail)
# ===============================
EMAIL_USER=SET_YOUR_EMAIL_USER_HERE
EMAIL_PASS=SET_YOUR_EMAIL_PASS_HERE

# ===============================
# SMS Config (Twilio)
# ===============================
TWILIO_SID=SET_YOUR_TWILIO_SID_HERE     # Your Account SID from Twilio Console
TWILIO_AUTH_TOKEN=SET_YOUR_TWILIO_AUTH_TOKEN_HERE     # Your Auth Token from Twilio Console  
TWILIO_PHONE=SET_YOUR_TWILIO_PHONE_HERE       # Your purchased Twilio phone number with country code


# ===============================
# GoogleOAuth Config
# ===============================
GOOGLE_CLIENT_ID=SET_YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=SET_YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=SET_YOUR_GOOGLE_CALLBACK_URL_HERE
SESSION_SECRET=SET_YOUR_SESSION_SECRET_HERE

# ===============================
# Razorpay Payment Gateway Config
# ===============================
# IMPORTANT: These credentials are ONLY for ADMIN SUBSCRIPTION PAYMENTS
# Admins configure their own credentials via /payment-config endpoints
# ===============================
RAZORPAY_KEY_ID=SET_YOUR_RAZORPAY_KEY_ID_HERE                      
RAZORPAY_KEY_SECRET=SET_YOUR_RAZORPAY_KEY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=SET_YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

# Razorpay Environment URLs (automatically handled by SDK)
# RAZORPAY_BASE_URL=https://api.razorpay.com/v1                     # Production (default)

# Razorpay Callback URLs
RAZORPAY_REDIRECT_URL=SET_YOUR_RAZORPAY_REDIRECT_URL_HERE
RAZORPAY_WEBHOOK_URL=SET_YOUR_RAZORPAY_WEBHOOK_URL_HERE
# ===============================
# Super Admin & Subscription Config
# ===============================
SUPER_ADMIN_MAX_OTP_ATTEMPTS=SET_YOUR_SUPER_ADMIN_MAX_OTP_ATTEMPTS_HERE
SUPER_ADMIN_OTP_EXPIRY_MINUTES=SET_YOUR_SUPER_ADMIN_OTP_EXPIRY_MINUTES_HERE
SUBSCRIPTION_GRACE_PERIOD_DAYS=SET_YOUR_SUBSCRIPTION_GRACE_PERIOD_DAYS_HERE
SUBSCRIPTION_REMINDER_DAYS=SET_YOUR_SUBSCRIPTION_REMINDER_DAYS_HERE

# Background Jobs (Set to false to disable)
ENABLE_SUBSCRIPTION_JOBS=true

# ===============================
# Assginment config
# ===============================
MAX_ORDERS_PER_WAITER=SET_YOUR_MAX_ORDERS_PER_WAITER_HERE
MONITORING_INTERVAL=SET_YOUR_MONITORING_INTERVAL_HERE
ORDER_TIMEOUT_MINUTES=SET_YOUR_ORDER_TIMEOUT_MINUTES_HERE
CLEANUP_INTERVAL=SET_YOUR_CLEANUP_INTERVAL_HERE
MAX_PREPARATION_TIME=SET_YOUR_MAX_PREPARATION_TIME_HERE
MAX_QUEUE_SIZE=SET_YOUR_MAX_QUEUE_SIZE_HERE
ENABLE_EMAIL_QUEUE=SET_YOUR_ENABLE_EMAIL_QUEUE_HERE  # Enable/disable email queue processor

# Frontend URL for payment redirects
FRONTEND_URL=SET_YOUR_FRONTEND_URL_HERE

# ===============================
# Multi-Provider Payment System
# ===============================
# CRITICAL: Generate encryption key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key is used to encrypt restaurant payment credentials in database
ENCRYPTION_KEY=SET_YOUR_ENCRYPTION_KEY_HERE

# Backend URL for webhooks (update in production)
BACKEND_URL=SET_YOUR_BACKEND_URL_HERE

# PhonePe Configuration (for future use)
PHONEPE_ENV=sandbox
# PHONEPE_ENV=production

# Paytm Configuration (for future use)  
PAYTM_ENV=staging
# PAYTM_ENV=production